# Common
confirm_os_window_close -1 count-background
map cmd+c launch --type=overlay --title="kitty cheatsheet" sh -c 'less ~/.config/kitty/cheatsheet.txt'

# BEGIN_KITTY_FONTS
font_family      family="JetBrainsMono Nerd Font Mono"
bold_font        auto
italic_font      auto
bold_italic_font auto
font_size 12.0
# END_KITTY_FONTS

# Bell
enable_audio_bell no

# Windows
initial_window_width  122
initial_window_height 34
draw_minimal_borders yes
new_tab_with_cwd

# Tabs
tab_bar_style powerline
tab_powerline_style round

# Background
background_opacity 0.9
background_blur 10

# Layout
enabled_layouts tall:bias=60;full_size=1;mirrored=false

# English shortcuts
map cmd+]       next_window
map cmd+[       previous_window
map cmd+d       close_window                

map cmd+enter        new_window_with_cwd
map cmd+t            new_tab_with_cwd
map cmd+n            new_os_window_with_cwd

# Russian shortcuts
map cmd+с       copy_to_clipboard           
map cmd+м       paste_from_clipboard        
map cmd+М       paste_from_selection       

# вкладки
map cmd+е       new_tab_with_cwd            
map cmd+ц       close_tab                   
map cmd+Ц       close_os_window            

# окна
map cmd+т       new_os_window_with_cwd      
map cmd+в       close_window                
map cmd+к       start_resizing_window       

# терминал
map cmd+л       clear_terminal to_cursor active   
map cmd+й       quit                        

# переключение между окнами (splits) внутри вкладки
map cmd+ъ       next_window
map cmd+х       previous_window

# BEGIN_KITTY_THEME
# Copland OS
include current-theme.conf
# END_KITTY_THEME

